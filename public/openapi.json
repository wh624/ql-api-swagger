{
  "openapi": "3.0.3",
  "info": {
    "title": "青龙面板 Open API",
    "description": "青龙面板 (Qinglong Panel) 开放接口文档\n\n## 认证流程\n\n1. **创建应用**: 系统设置 → 应用设置 → 添加应用，获取 `client_id` 和 `client_secret`\n2. **获取 Token**: `GET /open/auth/token?client_id=xxx&client_secret=xxx`\n3. **使用 Token**: 在请求头中添加 `Authorization: Bearer {token}`\n\n## 基础路径\n\n所有接口的基础路径为 `/open`。\n\n## 错误处理\n\n- 成功响应格式: `{ \"code\": 200, \"data\": ... }`\n- 错误由 Winston logger 统一处理",
    "version": "1.0.0",
    "contact": {
      "name": "Qinglong",
      "url": "https://github.com/whyour/qinglong"
    }
  },
  "servers": [
    {
      "url": "http://{host}:{port}/open",
      "description": "青龙面板服务器",
      "variables": {
        "host": {
          "default": "localhost",
          "description": "青龙面板服务器地址"
        },
        "port": {
          "default": "5700",
          "description": "青龙面板服务端口"
        }
      }
    }
  ],
  "tags": [
    { "name": "认证", "description": "Token 认证相关接口" },
    { "name": "定时任务", "description": "定时任务的增删改查、运行控制、视图管理等" },
    { "name": "订阅管理", "description": "订阅的创建、运行、启停等操作" },
    { "name": "环境变量", "description": "环境变量的增删改查、批量操作等" },
    { "name": "配置文件", "description": "配置文件的查看与编辑" },
    { "name": "脚本管理", "description": "脚本的上传、编辑、删除、运行等操作" },
    { "name": "依赖管理", "description": "依赖包的安装、卸载、重装等操作" },
    { "name": "日志管理", "description": "日志文件的查看与管理" },
    { "name": "系统设置", "description": "系统信息、配置、更新、通知等操作" }
  ],
  "paths": {
    "/auth/token": {
      "get": {
        "tags": ["认证"],
        "summary": "获取 Token",
        "description": "使用 client_id 和 client_secret 获取访问令牌",
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "创建应用时生成的 Client ID" },
          { "name": "client_secret", "in": "query", "required": true, "schema": { "type": "string" }, "description": "创建应用时生成的 Client Secret" }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer", "example": 200 },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string", "example": "xxxxxx" },
                        "token_type": { "type": "string", "example": "Bearer" },
                        "expiration": { "type": "integer", "example": 1237889999 }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/crons/views": {
      "get": {
        "tags": ["定时任务"],
        "summary": "获取视图列表",
        "responses": { "200": { "description": "成功" } }
      },
      "post": {
        "tags": ["定时任务"],
        "summary": "创建视图",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "sorts": { "type": "array", "items": {} },
                  "filters": { "type": "array", "items": {} },
                  "filterRelation": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "成功" } }
      },
      "put": {
        "tags": ["定时任务"],
        "summary": "更新视图",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" },
                  "sorts": { "type": "array", "items": {} },
                  "filters": { "type": "array", "items": {} },
                  "filterRelation": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "成功" } }
      },
      "delete": {
        "tags": ["定时任务"],
        "summary": "删除视图",
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "array", "items": { "type": "integer" } } } }
        },
        "responses": { "200": { "description": "成功" } }
      }
    },
    "/crons/views/move": {
      "put": {
        "tags": ["定时任务"],
        "summary": "移动视图位置",
